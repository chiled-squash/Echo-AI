{
  "manifest_version": 3,
  "name": "AI Chat Sync Launcher",
  "version": "1.0.0",
  "description": "Open multiple AI chat sites and sync sent prompts across tabs.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.kimi.com/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_title": "AI Chat Sync",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.kimi.com/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}